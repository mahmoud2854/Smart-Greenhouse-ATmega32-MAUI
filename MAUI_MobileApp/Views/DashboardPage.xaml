<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:SmartGreenhouseApp.ViewModels"
             x:Class="SmartGreenhouseApp.Views.DashboardPage"
             x:DataType="vm:DashboardViewModel"
             Title="Smart Greenhouse"
             BackgroundColor="#101217">

    <!-- Gradient Background -->
    <ContentPage.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#1A1D24" Offset="0.0" />
            <GradientStop Color="#101217" Offset="1.0" />
        </LinearGradientBrush>
    </ContentPage.Background>

    <ScrollView>
        <VerticalStackLayout Padding="15" Spacing="25">

            <!-- HEADER -->
            <Grid ColumnDefinitions="Auto,*,Auto" Padding="10,10,10,0">
                <Ellipse WidthRequest="12" HeightRequest="12" Fill="{Binding ConnectionColor}" VerticalOptions="Center"/>
                <Label Grid.Column="1" Text="{Binding StatusMessage}" FontSize="14" TextColor="{Binding ConnectionColor}" Margin="8,0,0,0" VerticalOptions="Center"/>
                
                <Label Grid.Column="0" Grid.ColumnSpan="3" Text="SMART GREENHOUSE" FontSize="18" FontAttributes="Bold" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center"/>
                
                <Frame Grid.Column="2" BackgroundColor="#2D333B" CornerRadius="15" Padding="5" HasShadow="False" WidthRequest="30" HeightRequest="30">
                    <Label Text="👤" HorizontalOptions="Center" VerticalOptions="Center" FontSize="12"/>
                </Frame>
            </Grid>

            <!-- GAUGES -->
            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="10" Margin="0,20,0,10">
                
                <!-- Temp Gauge -->
                <VerticalStackLayout>
                    <GraphicsView x:Name="TempGauge" WidthRequest="110" HeightRequest="110" HorizontalOptions="Center"/>
                    <Label Text="TEMPERATURE" FontSize="10" TextColor="#8B95A5" HorizontalOptions="Center" Margin="0,10,0,0" FontAttributes="Bold"/>
                </VerticalStackLayout>

                <!-- Humidity Gauge -->
                <VerticalStackLayout Grid.Column="1">
                    <GraphicsView x:Name="HumGauge" WidthRequest="110" HeightRequest="110" HorizontalOptions="Center"/>
                    <Label Text="HUMIDITY" FontSize="10" TextColor="#8B95A5" HorizontalOptions="Center" Margin="0,10,0,0" FontAttributes="Bold"/>
                </VerticalStackLayout>

                <!-- Soil Gauge -->
                <VerticalStackLayout Grid.Column="2">
                    <GraphicsView x:Name="SoilGauge" WidthRequest="110" HeightRequest="110" HorizontalOptions="Center"/>
                    <Label Text="SOIL MOISTURE" FontSize="10" TextColor="#8B95A5" HorizontalOptions="Center" Margin="0,10,0,0" FontAttributes="Bold"/>
                </VerticalStackLayout>
            </Grid>

            <!-- BLUETOOTH CONNECTION -->
            <Frame BackgroundColor="#161B22" BorderColor="#30363D" CornerRadius="16" Padding="15" HasShadow="False" Margin="0,10">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
                    <Entry Placeholder="Type port: COM3, COM5..."
                           Text="{Binding PortEntry}"
                           TextColor="White" PlaceholderColor="#636E72"
                           BackgroundColor="#0D1117"
                           FontSize="14"/>
                    <Button Grid.Column="1"
                            Text="{Binding ConnectButtonText}"
                            Command="{Binding ConnectCommand}"
                            BackgroundColor="{Binding ConnectionColor}"
                            TextColor="White" CornerRadius="12"
                            FontAttributes="Bold" HeightRequest="45"
                            MinimumWidthRequest="100"/>
                </Grid>
            </Frame>

            <!-- MANUAL CONTROLS -->
            <VerticalStackLayout Spacing="15" Margin="0,10,0,0">
                <Label Text="Manual Controls" FontSize="18" TextColor="White" HorizontalOptions="Center" FontAttributes="Bold"/>
                
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="15">
                    
                    <!-- PUMP TOGGLE -->
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding PumpStatusText, StringFormat='PUMP: {0}'}" FontSize="12" TextColor="#8B95A5" HorizontalOptions="Center" FontAttributes="Bold"/>
                        <Border Stroke="Transparent" BackgroundColor="{Binding PumpStatusColor}" StrokeShape="RoundRectangle 25" HeightRequest="45" WidthRequest="100" HorizontalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding TogglePumpCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,*">
                                <Label Text="💦" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Frame Grid.Column="1" BackgroundColor="#2D333B" CornerRadius="20" Padding="0" Margin="2" HasShadow="False">
                                    <Label Text="{Binding PumpStatusText}" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                                </Frame>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- FAN TOGGLE -->
                    <VerticalStackLayout Grid.Column="1" Spacing="8">
                        <Label Text="{Binding FanStatusText, StringFormat='FAN: {0}'}" FontSize="12" TextColor="#8B95A5" HorizontalOptions="Center" FontAttributes="Bold"/>
                        <Border Stroke="Transparent" BackgroundColor="{Binding FanStatusColor}" StrokeShape="RoundRectangle 25" HeightRequest="45" WidthRequest="100" HorizontalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleFanCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,*">
                                <Label Text="🌀" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Frame Grid.Column="1" BackgroundColor="#2D333B" CornerRadius="20" Padding="0" Margin="2" HasShadow="False">
                                    <Label Text="{Binding FanStatusText}" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                                </Frame>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <!-- LIGHT TOGGLE -->
                    <VerticalStackLayout Grid.Column="2" Spacing="8">
                        <Label Text="{Binding LightStatusText, StringFormat='LIGHT: {0}'}" FontSize="12" TextColor="#8B95A5" HorizontalOptions="Center" FontAttributes="Bold"/>
                        <Border Stroke="Transparent" BackgroundColor="{Binding LightStatusColor}" StrokeShape="RoundRectangle 25" HeightRequest="45" WidthRequest="100" HorizontalOptions="Center">
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Command="{Binding ToggleLightCommand}"/>
                            </Border.GestureRecognizers>
                            <Grid ColumnDefinitions="*,*">
                                <Label Text="💡" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                                <Frame Grid.Column="1" BackgroundColor="#2D333B" CornerRadius="20" Padding="0" Margin="2" HasShadow="False">
                                    <Label Text="{Binding LightStatusText}" FontSize="12" TextColor="White" HorizontalOptions="Center" VerticalOptions="Center" FontAttributes="Bold"/>
                                </Frame>
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                </Grid>
            </VerticalStackLayout>

            <!-- RESET AUTO BUTTON -->
            <Button Text="🔄 Reset to AUTO Mode" Command="{Binding ResetAutoCommand}"
                    BackgroundColor="#2D333B" TextColor="#8B95A5" CornerRadius="12"
                    FontAttributes="Bold" HeightRequest="46" FontSize="14" Margin="0,20,0,0"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
